# ──────────────────────────────────────────────
# Enterprise SAP OData Chatbot — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
#   cp .env.example .env

# ── LLM API Keys ──────────────────────────────
# Groq (primary — fast inference)
GROQ_API_KEY=your_groq_api_key_here

# Optional alternative providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# ── SurrealDB Config ───────────────────────────
# Local mode  → ws://localhost:8001/rpc  (Docker exposes SurrealDB on host port 8001)
# Docker mode → handled automatically via docker-compose environment overrides
SURREAL_URL=ws://localhost:8001/rpc
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=sap
SURREAL_DB=odata

# ── Ollama Embedding Engine ────────────────────
# Option A: Use your already-running local Ollama  (default)
OLLAMA_BASE_URL=http://localhost:11434
# Option B: Use the docker-compose containerized Ollama (port 11435)
# OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_MODEL=nomic-embed-text

# ── SAP OData Gateway ─────────────────────────
# Replace with your real SAP CPI / OData endpoint URL
SAP_ODATA_BASE_URL=https://your-sap-gateway.example.com/sap/opu/odata/sap/YOUR_SERVICE/
SAP_CLIENT=100
SAP_ODATA_USER=your_sap_username
SAP_ODATA_PASS=your_sap_password

# ── Code Sandbox ──────────────────────────────
# Set USE_DOCKER=true to run generated Python code in isolated Docker containers
USE_DOCKER=false
SANDBOX_DOCKER_IMAGE=python:3.10-alpine
SANDBOX_TIMEOUT_SECONDS=30

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Pagination ────────────────────────────────
ODATA_PAGINATION_LIMIT=100
