# ──────────────────────────────────────────────
# Enterprise SAP OData Chatbot — Environment Config
# ──────────────────────────────────────────────

# Groq LLM API
GROQ_API_KEY=your_groq_api_key_here
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# SurrealDB
SURREAL_URL=ws://localhost:8001/rpc
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=sap
SURREAL_DB=odata

# Ollama (Local Embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# SAP OData Gateway (placeholder — configure when ready)
SAP_ODATA_BASE_URL=https://sap-gateway.example.com/sap/opu/odata/sap/
SAP_CLIENT=100

# Code Sandbox
SANDBOX_DOCKER_IMAGE=python:3.10-alpine
SANDBOX_TIMEOUT_SECONDS=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
